# ---------------------------------------------------------------------------
# Nexwavy Website MVP — environment variables (ADR-001)
# Copy this file to `.env.local` and fill what you have. Everything is optional
# for local dev: with NO keys set, the app runs on an in-memory database, mocks
# emails to the server console, and offers a "dev login" instead of Google.
# Add real keys to go live, one integration at a time.
# ---------------------------------------------------------------------------

# --- Auth (NextAuth / Auth.js) ---------------------------------------------
# Required in production. Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Your site URL (e.g. https://nexwavy.com). For local dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Google Sign-In (Google Cloud Console > OAuth 2.0 Client).
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# When Google is NOT configured, a dev-login provider is auto-enabled.
# Set this to "true" to ALSO allow dev login when Google IS configured (dev only).
ALLOW_DEV_LOGIN=

# --- Admin allowlist --------------------------------------------------------
# Comma/space separated emails allowed into /admin. Enforced server-side.
ADMIN_EMAILS=femi@nexwavy.com

# --- Database (PostgreSQL via Supabase or Neon) -----------------------------
# Set BOTH url and a key to switch off the in-memory store. Server-side only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Alternative to the service role key (used only if SERVICE_ROLE is empty):
SUPABASE_ANON_KEY=

# --- Email (Resend) ---------------------------------------------------------
# Without RESEND_API_KEY, emails are logged to the console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="Nexwavy Solutions <hello@nexwavy.com>"

# --- Payments (Paystack / Flutterwave hosted LINK — Phase 1) ----------------
# Per-course links take priority; otherwise the default link is used.
# Course id -> PAYMENT_LINK_<UPPER_SNAKE>:
PAYMENT_LINK_MASTERCLASS_FOUNDATIONS=
PAYMENT_LINK_MASTERCLASS_TEAM=
PAYMENT_LINK_MASTERCLASS_BUILDERS=
# Global fallback link if a per-course link isn't set:
PAYMENT_LINK_DEFAULT=
